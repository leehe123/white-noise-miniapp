/* pages/index/index.wxss */
/* 白噪音哄睡 · 母婴极简风 · 页面级样式 */

.page {
  min-height: 100vh;
  background: var(--bg);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 分区标题 */
.section-header {
  margin-top: 40rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: var(--fs-lg);
  font-weight: 700;
  color: var(--text);
  letter-spacing: 2rpx;
}

/* 白噪音 4列网格 */
.noise-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

/* 每个卡片占约 25%，4列 */
.noise-item {
  width: 22%;
  margin-bottom: 20rpx;
}

/* 底部留白 */
.page-footer {
  height: 100rpx;
}
