/* components/cry-detector/cry-detector.wxss */
/* 母婴极简风 · 视觉升级 */

.cry {
  width: 100%;
  padding: 16rpx var(--gap-lg) 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* ====== 标题 ====== */
.cry__header {
  text-align: center;
  margin-bottom: 28rpx;
}

.cry__title {
  font-size: var(--fs-lg);
  color: var(--text);
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* ====== 舞台 ====== */
.cry__stage {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}

.cry__stage--loading {
  padding-top: 56rpx;
}

/* ====== 录音按钮 ====== */
.cry__btn {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 100%);
  box-shadow: 0 14rpx 44rpx rgba(232, 196, 184, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.16s ease, box-shadow 0.22s ease;
}

.cry__btn--hover {
  transform: scale(0.95);
  box-shadow: 0 8rpx 24rpx rgba(232, 196, 184, 0.28);
}

.cry__btn--recording {
  background: linear-gradient(135deg, var(--primary-deep) 0%, #E8A88A 100%);
  box-shadow: 0 14rpx 52rpx rgba(212, 168, 142, 0.55);
  animation: btn-breathe 1.6s ease-in-out infinite;
}

@keyframes btn-breathe {
  0%, 100% { box-shadow: 0 14rpx 44rpx rgba(232, 196, 184, 0.4); }
  50%      { box-shadow: 0 20rpx 64rpx rgba(232, 196, 184, 0.65); }
}

/* 小号按钮（再录一次） */
.cry__btn--small {
  width: auto;
  height: auto;
  padding: 22rpx 60rpx;
  border-radius: 100rpx;
  background: var(--card);
  box-shadow: var(--shadow-sm);
  margin-top: 28rpx;
}

/* ====== 按钮内部文字 ====== */
.cry__btn-icon {
  font-size: 88rpx;
  line-height: 1;
  margin-bottom: 10rpx;
  opacity: 0.9;
}

.cry__btn-icon--recording {
  font-size: 104rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 0;
  letter-spacing: 0;
}

.cry__btn-text {
  font-size: var(--fs-sm);
  color: var(--text-sub);
  letter-spacing: 1rpx;
  font-weight: 500;
}

.cry__btn-text--recording {
  color: #fff;
  font-size: var(--fs-sm);
  opacity: 0.85;
}

.cry__btn-text--small {
  color: var(--primary-deep);
  font-size: var(--fs);
  font-weight: 600;
}

/* ====== 录音中脉冲圆环 ====== */
.cry__pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 300rpx;
  height: 300rpx;
  margin-top: -150rpx;
  margin-left: -150rpx;
  border-radius: 50%;
  border: 3rpx solid var(--primary-deep);
  opacity: 0;
  animation: cry-pulse 1.5s ease-out infinite;
  pointer-events: none;
}

.cry__pulse--delay {
  animation-delay: 0.75s;
}

@keyframes cry-pulse {
  0%   { transform: scale(1);   opacity: 0.45; }
  100% { transform: scale(1.7); opacity: 0; }
}

/* ====== Loading spinner ====== */
.cry__spinner {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 36rpx;
}

.cry__spinner-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: 4rpx solid transparent;
  border-top-color: var(--primary-deep);
  border-radius: 50%;
  animation: cry-spin 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
}

.cry__spinner-ring--2 {
  width: 88rpx;
  height: 88rpx;
  top: 16rpx;
  left: 16rpx;
  border-top-color: var(--primary);
  animation-delay: 0.15s;
}

.cry__spinner-ring--3 {
  width: 56rpx;
  height: 56rpx;
  top: 32rpx;
  left: 32rpx;
  border-top-color: var(--accent);
  animation-delay: 0.3s;
}

@keyframes cry-spin {
  0%   { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.cry__loading-text {
  font-size: var(--fs-md);
  color: var(--text);
  font-weight: 600;
  margin-top: 8rpx;
}

.cry__loading-tip {
  margin-top: 14rpx;
  font-size: var(--fs-sm);
  color: var(--text-sub);
  text-align: center;
  padding: 0 40rpx;
  line-height: 1.5;
}

/* ====== 结果卡片 ====== */
.cry__result {
  width: 100%;
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 52rpx 36rpx 44rpx;
  text-align: center;
  box-shadow: var(--shadow-md);
}

.cry__result-emoji {
  font-size: 100rpx;
  line-height: 1;
  margin-bottom: 18rpx;
}

.cry__result-label {
  font-size: var(--fs-sm);
  color: var(--text-sub);
  letter-spacing: 1rpx;
}

.cry__result-name {
  font-size: 60rpx;
  color: var(--text);
  font-weight: 700;
  margin: 10rpx 0 18rpx;
  letter-spacing: 4rpx;
}

.cry__result-confidence {
  display: inline-block;
  padding: 8rpx 26rpx;
  border-radius: 100rpx;
  font-size: var(--fs-sm);
  margin-bottom: 22rpx;
  font-weight: 500;
}

.cry__result-confidence.is-high {
  background: rgba(184, 216, 194, 0.35);
  color: #4E7A58;
}

.cry__result-confidence.is-mid {
  background: rgba(232, 196, 184, 0.4);
  color: #A06850;
}

.cry__result-confidence.is-low {
  background: rgba(168, 155, 140, 0.25);
  color: #7A6F60;
}

.cry__result-warn {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #A06850;
  background: rgba(232, 196, 184, 0.3);
  margin-bottom: 22rpx;
  margin-left: 12rpx;
}

.cry__result-tip {
  font-size: var(--fs);
  color: var(--text-sub);
  letter-spacing: 1rpx;
  line-height: 1.6;
  padding: 0 20rpx;
}

/* ====== 错误状态 ====== */
.cry__error {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.cry__error-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.cry__error-text {
  font-size: var(--fs);
  color: #A06850;
  letter-spacing: 1rpx;
  text-align: center;
  padding: 0 40rpx;
  line-height: 1.6;
}

.cry__error-detail {
  margin-top: 12rpx;
  font-size: var(--fs-sm);
  color: var(--text-tip);
  text-align: center;
  padding: 0 40rpx;
}
